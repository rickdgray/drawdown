{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug 4pct Rule",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/release_debug/drawdown",
            "preLaunchTask": "build drawdown",
            "args": [
                "constant-dollar",
                "-w", "4",
                "-p", "\"us_stocks:60;us_bonds:40;\"",
                "-y",  "30"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}